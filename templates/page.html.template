<script>
(function(){
  var KEY = 'cashPromoDismissed';
  var PROMO = document.getElementById('cashPromo');
  if (!PROMO) return;

  // Don't show if dismissed in last 24h
  try {
    var dismissed = localStorage.getItem(KEY);
    if (dismissed && (Date.now() - parseInt(dismissed, 10)) < 86400000) return;
  } catch(e) {}

  function show() {
    PROMO.setAttribute('aria-hidden', 'false');
    PROMO.style.pointerEvents = 'auto';
    PROMO.style.transform = 'translateY(0)';
    PROMO.style.opacity = '1';
  }
  function hide() {
    PROMO.style.transform = 'translateY(140%)';
    PROMO.style.opacity = '0';
    PROMO.style.pointerEvents = 'none';
    PROMO.setAttribute('aria-hidden', 'true');
    try { localStorage.setItem(KEY, String(Date.now())); } catch(e) {}
  }

  // Slide in after 4s
  setTimeout(show, 4000);

  document.getElementById('cashPromoClose').addEventListener('click', hide);
  document.getElementById('cashPromoLater').addEventListener('click', hide);
})();
</script>

