<!-- Booking modal -->
<div class="modal" id="bookModal" hidden aria-hidden="true" role="dialog" aria-labelledby="bookModalTitle">
  <div class="modal-backdrop" data-close-book></div>
  <div class="modal-card" role="document">
    <button class="modal-close" type="button" data-close-book aria-label="Close">×</button>
    <h2 id="bookModalTitle">Book your charter</h2>
    <p class="modal-sub">Send your details — we'll reply on WhatsApp within 5 minutes with available boats &amp; final price.</p>
    <form id="bookForm" novalidate>
      <label>Your name
        <input type="text" name="name" required autocomplete="name" placeholder="e.g. Sophie">
      </label>
      <div class="modal-row">
        <label>Date
          <input type="date" name="date" autocomplete="off">
        </label>
        <label>Guests
          <input type="number" name="guests" min="1" max="12" inputmode="numeric" placeholder="6">
        </label>
      </div>
      <label>Boat (optional)
        <select name="boat">
          <option value="">Recommend me a boat</option>
          <option>Astondoa 40 'Fufi' — €749 / 2h · 9 guests</option>
          <option>Azimut 39 — €749 / 2h · 11 guests</option>
          <option>Mangusta 80 — €4,719 / 4h · 12 guests + jet ski</option>
          <option>Dubhe (licence-free) — €230 / 2h · 5 guests</option>
          <option>Jet ski — €200 / h</option>
          <option>Another boat from the fleet</option>
        </select>
      </label>
      <label>Anything else?
        <textarea name="notes" rows="2" placeholder="Sunset preferred, one birthday on board…"></textarea>
      </label>
      <button class="btn btn-primary" type="submit">💬 Continue in WhatsApp</button>
      <p class="modal-micro">Opens WhatsApp with your message pre-filled — you send it from your own number. Average reply under 5 minutes.</p>
    </form>
  </div>
</div>

<script>
(function(){
  var modal = document.getElementById('bookModal');
  if (!modal) return;
  var waNum = '{{WHATSAPP_E164_NOPLUS}}';
  function open(){ modal.hidden = false; modal.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; var f=modal.querySelector('input[name=name]'); if(f) setTimeout(function(){f.focus();},50); }
  function close(){ modal.hidden = true; modal.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  document.querySelectorAll('[data-open-book]').forEach(function(b){ b.addEventListener('click', open); });
  document.querySelectorAll('[data-close-book]').forEach(function(b){ b.addEventListener('click', close); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape' && !modal.hidden) close(); });
  document.getElementById('bookForm').addEventListener('submit', function(e){
    e.preventDefault();
    var f = e.target;
    var name = (f.name.value||'').trim();
    var date = (f.date.value||'').trim();
    var guests = (f.guests.value||'').trim();
    var boat = (f.boat.value||'').trim();
    var notes = (f.notes.value||'').trim();
    var nameInput = f.querySelector('input[name=name]');
    if(!name){ nameInput.setAttribute('aria-invalid','true'); nameInput.style.borderColor='#d9534f'; nameInput.focus(); return; }
    var lines = ['Hi, I\'d like to book a boat in Marbella. — '+name];
    if(date) lines.push('Date: '+date);
    if(guests) lines.push('Guests: '+guests);
    if(boat) lines.push('Boat: '+boat);
    if(notes) lines.push(notes);
    var msg = encodeURIComponent(lines.join('\n'));
    window.location.href = 'https://wa.me/'+waNum+'?text='+msg;
  });
  // Focus trap inside the modal while open
  modal.addEventListener('keydown', function(e){
    if(e.key !== 'Tab' || modal.hidden) return;
    var els = modal.querySelectorAll('button, input, select, textarea, a[href]');
    if(!els.length) return;
    var first = els[0], last = els[els.length-1];
    if(e.shiftKey && document.activeElement === first){ e.preventDefault(); last.focus(); }
    else if(!e.shiftKey && document.activeElement === last){ e.preventDefault(); first.focus(); }
  });
})();
</script>

